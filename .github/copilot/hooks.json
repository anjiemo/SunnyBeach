{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python .github/copilot/hooks/session-start.py",
        "timeout": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "python .github/copilot/hooks/inject-workflow-state.py",
        "powershell": "python .github/copilot/hooks/inject-workflow-state.py",
        "timeoutSec": 15
      }
    ]
  }
}
